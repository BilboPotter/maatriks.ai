---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../lib/site.mjs';
import { loadBlogPosts } from '../../lib/blog.mjs';

export function getStaticPaths() {
  const posts = loadBlogPosts();

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, posts },
  }));
}

const { post, posts } = Astro.props;
const relatedPosts = posts.filter((entry) => entry.slug !== post.slug).slice(0, 3);
const backLinkHtml = '<a href="/blog" class="blog-back-link">&larr; All posts</a>';
---

<BaseLayout
  pageTitle={`${post.title} — ${siteConfig.appName}`}
  pageDescription={post.description}
  canonicalUrl={`${siteConfig.siteUrl}/blog/${post.slug}`}
  pageClass="content-page blog-page blog-post-page"
>
  <section class="blog-article-hero section-block">
    <div class="container">
      <Fragment set:html={backLinkHtml} />

      <div class="blog-card-meta blog-post-meta">
        <span class="blog-kicker">{post.category}</span>
        <time datetime={post.date}>{post.dateLong}</time>
        <span>{post.readingTimeLabel}</span>
      </div>

      <header class="blog-article-head">
        <p class="blog-feature-label">Journal entry</p>
        <h1>{post.title}</h1>
        <p class="blog-article-dek">{post.description}</p>
      </header>
    </div>
  </section>

  <section class="blog-article-content section-block">
    <div class="container">
      <div class="blog-article-layout">
        <aside class="blog-article-side" aria-label="Article metadata">
          <div class="blog-side-block">
            <p class="blog-feature-label">Published</p>
            <p>{post.dateLong}</p>
          </div>
          <div class="blog-side-block">
            <p class="blog-feature-label">Category</p>
            <p>{post.category}</p>
          </div>
          <div class="blog-side-block">
            <p class="blog-feature-label">Reading time</p>
            <p>{post.readingTimeLabel}</p>
          </div>
        </aside>

        <article class="content-body blog-article-body">
          <Fragment set:html={post.content} />
        </article>
      </div>
    </div>
  </section>

  {relatedPosts.length === 0 ? (
    <section class="blog-related-section blog-related-section--solo">
      <div class="container">
        <div class="blog-related-empty">
          <p class="blog-feature-label">Journal</p>
          <h2>More writing is coming.</h2>
          <p>More notes on training, adaptation, and building the app will land here soon.</p>
          <a href="/blog" class="btn btn-ghost">Back to all posts</a>
        </div>
      </div>
    </section>
  ) : (
    <section class="blog-related-section">
      <div class="container">
        <div class="blog-section-head">
          <div>
            <p class="blog-feature-label">Continue reading</p>
            <h2>More from the journal</h2>
          </div>
          <a href="/blog" class="blog-section-link">All posts</a>
        </div>
        <div class="blog-related-grid">
          {relatedPosts.map((entry) => (
            <article class="blog-related-card">
              <a href={`/blog/${entry.slug}`} class="blog-related-link">
                <div class="blog-card-meta">
                  <span class="blog-kicker">{entry.category}</span>
                  <span>{entry.dateShort}</span>
                </div>
                <h3>{entry.title}</h3>
                <p>{entry.description}</p>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
