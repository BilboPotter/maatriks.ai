---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../lib/site.mjs';
import { loadBlogPosts, renderBlogPostContent } from '../../lib/blog.mjs';

export function getStaticPaths() {
  return loadBlogPosts().map((post) => ({
    params: { slug: post.slug },
    props: { post, posts: loadBlogPosts() },
  }));
}

const { post, posts } = Astro.props;
const content = renderBlogPostContent(post, posts);
---

<BaseLayout
  pageTitle={`${post.title} — ${siteConfig.appName}`}
  pageDescription={post.description}
  canonicalUrl={`${siteConfig.siteUrl}/blog/${post.slug}`}
  pageClass="content-page blog-page blog-post-page"
>
  <Fragment set:html={content} />
</BaseLayout>
