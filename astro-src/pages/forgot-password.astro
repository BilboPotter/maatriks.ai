---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailLink from '../components/EmailLink.astro';
import { siteConfig } from '../lib/site.mjs';
---

<BaseLayout
  pageTitle={`Reset Password — ${siteConfig.appName}`}
  pageDescription={`How to reset your ${siteConfig.appName} password.`}
  canonicalUrl={`${siteConfig.siteUrl}/forgot-password`}
  pageClass="content-page"
  robotsContent="noindex, nofollow"
>
  <div class="container">
    <div class="section-label">Account Recovery</div>
    <h1>Reset Password</h1>
    <p class="page-meta">How to start password recovery for {siteConfig.appName}</p>

    <div class="content-body">
      <p class="lead">Password reset requests should be started from the mobile app sign-in screen. The reset email will send you through a secure browser handoff page and then back into the app to finish the reset.</p>

      <h2>How to start the reset</h2>
      <ol>
        <li>Open the {siteConfig.appName} app</li>
        <li>Go to the sign-in screen</li>
        <li>Tap <strong>Forgot password</strong></li>
        <li>Enter the email address tied to your account</li>
        <li>Open the reset email on the same mobile device where {siteConfig.appName} is installed and continue from the recovery link</li>
      </ol>

      <h2>Troubleshooting</h2>
      <ol>
        <li>Check spam or junk if the reset email does not arrive within a few minutes</li>
        <li>Make sure you entered the same email address used for your {siteConfig.appName} account</li>
        <li>If the recovery link opens the browser first, use the handoff page button to continue back into the app</li>
        <li>If the reset link has expired, request a new password reset email from the sign-in screen</li>
      </ol>

      <h2>Need help?</h2>
      <p>If the reset email does not arrive or the recovery link does not open the app correctly, contact support from the email address associated with your account when possible:</p>
      <EmailLink email={siteConfig.supportEmail} />

      <div class="section-divider"></div>

      <h2>Related pages</h2>
      <ul>
        <li><a href={siteConfig.supportUrl}>Support</a> {'\u2014'} general help and contact</li>
        <li><a href={siteConfig.privacyUrl}>Privacy Policy</a> {'\u2014'} how we handle account data</li>
      </ul>
    </div>
  </div>
</BaseLayout>
