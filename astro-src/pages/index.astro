---
import BaseLayout from '../layouts/BaseLayout.astro';
import LegacyPartial from '../components/LegacyPartial.astro';
import { siteConfig } from '../lib/site.mjs';

const leftArrowHtml = '&larr;';
const rightArrowHtml = '&rarr;';
const homepageTitle = 'maatriks — Workout App That Adapts to You';
const homepageDescription = 'maatriks builds a personalized workout plan, tracks what you actually did, and adjusts your next session automatically. Simple enough for beginners, smart enough for experienced lifters.';
const homepageSocialDescription = 'maatriks builds your workout plan, tracks what you actually did, and adjusts your next session automatically. Easy to use. Hard to outgrow.';
const homepageStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'maatriks',
    applicationCategory: 'HealthApplication',
    operatingSystem: 'iOS, Android',
    description: 'Adaptive workout programming app that builds personalized plans, tracks real performance, and adjusts automatically after every session. Works for any experience level.',
    url: 'https://maatriks.ai',
    author: {
      '@type': 'Organization',
      name: 'Riverin OÜ',
      url: 'https://maatriks.ai',
    },
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
      availability: 'https://schema.org/ComingSoon',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Do I need gym experience to use maatriks?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: "No. Tell it your schedule and goals, and it builds your first workout from there. You do not need to know exercises or programming. The app handles that. Experienced lifters get the same adaptive engine without managing their own spreadsheets.",
        },
      },
      {
        '@type': 'Question',
        name: 'How does the app know what to change after each workout?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'It uses what you actually logged — sets, reps, weight, and any swaps you made. If you went heavier, it adjusts up. If you cut a session short, it adapts. Every workout informs the next one.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can I change exercises during a workout?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. Swap anything mid-session and the app treats it as part of the record. Your plan adjusts based on what you actually did, not what was originally scheduled.',
        },
      },
      {
        '@type': 'Question',
        name: 'Is this a fixed workout plan or does it change?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'It changes. You start with a structured plan based on your setup, but after each session the app reviews what happened and adjusts what comes next. The longer you use it, the more tailored it gets.',
        },
      },
      {
        '@type': 'Question',
        name: 'How is this different from a personal trainer?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'A trainer costs 50-120 per session. maatriks gives you a personalized plan that adapts after every workout, with written feedback explaining what changed and why. It is not a human coach, but it pays closer attention than a static app or a spreadsheet.',
        },
      },
    ],
  },
];
---

<BaseLayout
  pageTitle={homepageTitle}
  pageDescription={homepageDescription}
  socialTitle={homepageTitle}
  socialDescription={homepageSocialDescription}
  siteName="maatriks"
  structuredData={homepageStructuredData}
  canonicalUrl={`${siteConfig.siteUrl}/`}
  mainStyle="padding:0;"
>
  <div class="story-shell" id="story-shell">
    <svg class="snake-line" id="snake-line" aria-hidden="true" viewBox="0 0 100 100" preserveAspectRatio="none">
      <path class="snake-path-bg" id="snake-path-bg"></path>
      <path class="snake-path-lit" id="snake-path-lit"></path>
    </svg>

    <section class="hero story-section story-section--hero" id="hero">
      <picture class="hero-bg">
        <source
          media="(max-width: 768px)"
          srcset="/assets/hero-gym-mobile-960.webp 960w, /assets/hero-gym-mobile-1440.webp 1440w"
          sizes="100vw" />
        <source
          srcset="/assets/hero-gym-desktop-1800.webp 1800w, /assets/hero-gym-desktop-2400.webp 2400w"
          sizes="100vw" />
        <img
          src="/assets/hero-gym-desktop-1800.webp"
          alt="Person training alone in a gym"
          width="1800"
          height="1005"
          fetchpriority="high"
          decoding="async" />
      </picture>

      <div class="container hero-inner">
        <div class="hero-copy">
          <h1><span class="hero-title-intro">Just show up.</span> <span class="accent">We&apos;ll handle the plan.</span></h1>
          <div class="hero-actions">
            <LegacyPartial name="store-badges" />
          </div>
        </div>

        <div class="hero-phone story-phone" data-snake-anchor>
          <div class="device" role="img" aria-label="maatriks workout preview for Full Body C showing weekly progress, coach review, and a start session action">
            <div class="device-inner">
              <LegacyPartial name="phone-workout" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="journey-section journey-section-clean phone-left" id="step-onboard">
      <div class="container journey-inner">
        <div class="journey-header reveal">
          <div class="step-number">1</div>
          <h2>Tell us about you</h2>
        </div>

        <div class="journey-copy reveal">
          <p class="journey-summary">
            How many days can you train? How long are your sessions? What do you want to focus on? Your first week is built
            from your answers, not a generic template.
          </p>
        </div>

        <div class="story-phone reveal reveal-left" data-snake-anchor>
          <div class="device" role="img" aria-label="maatriks onboarding screen asking for training experience level with New selected">
            <div class="device-inner">
              <LegacyPartial name="phone-onboarding" />
            </div>
          </div>
        </div>

        <div class="journey-support reveal">
          <div class="card journey-card">
            <div class="journey-card-label">What this step sets</div>
            <dl class="journey-facts">
              <div class="journey-fact">
                <dt>Input</dt>
                <dd>Your schedule, session length, and training goal.</dd>
              </div>
              <div class="journey-fact">
                <dt>System</dt>
                <dd>Your first week is shaped by what actually fits your life.</dd>
              </div>
              <div class="journey-fact">
                <dt>Outcome</dt>
                <dd>A plan that makes sense from day one, with no guessing what to do.</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </section>

    <section class="journey-section journey-section-photo phone-right" id="step-log">
      <picture class="split-photo">
        <source media="(min-width: 769px)" srcset="/assets/bg-log-workout.webp" />
        <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==" alt="Person training in a gym" width="1600" height="893" loading="lazy" decoding="async" />
      </picture>

      <div class="container journey-inner">
        <div class="journey-header reveal">
          <div class="step-number">2</div>
          <h2>Track what actually happened</h2>
        </div>

        <div class="journey-copy reveal">
          <p class="journey-summary">
            Finished early? Swapped an exercise? Went heavier than planned? Log it as it happened. Your next workout adjusts
            based on what you actually did, not what was scheduled.
          </p>
        </div>

        <div class="story-phone reveal reveal-right" data-snake-anchor>
          <div class="device" role="img" aria-label="maatriks active workout logging screen for Full Body C with set entry rows for overhead press and Romanian deadlift">
            <div class="device-inner">
              <LegacyPartial name="phone-workout-leg" />
            </div>
          </div>
        </div>

        <div class="journey-support reveal">
          <div class="card journey-card">
            <div class="journey-card-label">What this step captures</div>
            <dl class="journey-facts">
              <div class="journey-fact">
                <dt>Input</dt>
                <dd>Sets, reps, weight, and any changes you made mid-workout.</dd>
              </div>
              <div class="journey-fact">
                <dt>System</dt>
                <dd>The app separates what you finished, what you skipped, and what you changed.</dd>
              </div>
              <div class="journey-fact">
                <dt>Outcome</dt>
                <dd>Your next session is built on real data, not an idealized plan.</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </section>

    <section class="journey-section journey-section-clean journey-section-accent phone-left" id="step-feedback">
      <div class="container journey-inner">
        <div class="journey-header reveal">
          <div class="step-number">3</div>
          <h2>See why your plan is changing</h2>
        </div>

        <div class="journey-copy reveal">
          <p class="journey-summary">
            After each session, maatriks reviews what you did and explains what it will adjust next time and why. Not generic
            encouragement. Actual feedback on your actual workout.
          </p>
        </div>

        <div class="story-phone reveal reveal-left" data-snake-anchor>
          <div class="device" role="img" aria-label="maatriks workout reflection screen showing coach feedback, total volume, exercise stats, and a save and close action">
            <div class="device-inner">
              <LegacyPartial name="phone-feedback" />
            </div>
          </div>
        </div>

        <div class="journey-support reveal">
          <div class="card journey-card">
            <div class="journey-card-label">What this step explains</div>
            <dl class="journey-facts">
              <div class="journey-fact">
                <dt>Input</dt>
                <dd>Your completed session and recent training history.</dd>
              </div>
              <div class="journey-fact">
                <dt>System</dt>
                <dd>The app writes structured notes explaining what worked, what to change, and why.</dd>
              </div>
              <div class="journey-fact">
                <dt>Outcome</dt>
                <dd>You always know the reason behind your next workout.</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </section>

    <section class="journey-section journey-section-photo phone-right" id="step-results">
      <picture class="split-photo">
        <source media="(min-width: 769px)" srcset="/assets/bg-results.webp" />
        <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==" alt="Person training in a gym" width="1600" height="894" loading="lazy" decoding="async" />
      </picture>

      <div class="container journey-inner">
        <div class="journey-header reveal">
          <div class="step-number">4</div>
          <h2>Watch yourself get stronger</h2>
        </div>

        <div class="journey-copy reveal">
          <p class="journey-summary">
            Streaks, personal records, workout history, and progress trends all in one place. No spreadsheet needed. You can
            see whether the plan is working without doing the math yourself.
          </p>
        </div>

        <div class="story-phone reveal reveal-right" data-snake-anchor>
          <div class="device" role="img" aria-label="maatriks dashboard showing level progress, calendar history, and recent workouts">
            <div class="device-inner">
              <LegacyPartial name="phone-dashboard" />
            </div>
          </div>
        </div>

        <div class="journey-support reveal">
          <div class="card journey-card">
            <div class="journey-card-label">What this step surfaces</div>
            <dl class="journey-facts">
              <div class="journey-fact">
                <dt>Input</dt>
                <dd>Every workout you have logged.</dd>
              </div>
              <div class="journey-fact">
                <dt>System</dt>
                <dd>The dashboard tracks streaks, PRs, volume, and trends automatically.</dd>
              </div>
              <div class="journey-fact">
                <dt>Outcome</dt>
                <dd>You can see your progress at a glance, and so can the app.</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </section>
  </div>

  <section class="reviews-section section-block" id="reviews">
    <picture class="split-photo split-photo-left">
      <source media="(min-width: 769px)" srcset="/assets/bg-reviews.webp" />
      <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==" alt="Person resting after a workout in a gym" width="1600" height="893" loading="lazy" decoding="async" />
    </picture>

    <div class="container reviews-layout">
      <div class="reviews-copy reveal">
        <div class="section-label">Reviews</div>
        <h2>What early users are saying</h2>
        <p>Real beginner problems, plain-language reactions, and exactly the kind of reassurance people look for before they start.</p>
      </div>

      <div class="reviews-carousel reveal" data-carousel>
        <div class="reviews-track" data-carousel-track tabindex="0" aria-label="User reviews">
          <article class="review-card">
            <div class="review-stars">★★★★★</div>
            <p>"I used to stand around not knowing what to do next. Now I open the app and my workout is there. It even changed after I couldn't finish last time."</p>
            <div class="review-author">Anna, new to the gym</div>
          </article>
          <article class="review-card">
            <div class="review-stars">★★★★★</div>
            <p>"I tracked everything in Google Sheets for two years. This does the same thing but actually adjusts the plan based on what I log. Should have switched earlier."</p>
            <div class="review-author">Tom, switched from spreadsheets</div>
          </article>
          <article class="review-card">
            <div class="review-stars">★★★★★</div>
            <p>"Other apps gave me the same workout every week. This one noticed I was getting stronger and added weight. That's all I wanted."</p>
            <div class="review-author">Laura, tried 3 apps before this</div>
          </article>
          <article class="review-card">
            <div class="review-stars">★★★★★</div>
            <p>"Can't afford a personal trainer. This is the closest thing I've found. It tells me what to do and explains why when things change."</p>
            <div class="review-author">Erik, training with no coach</div>
          </article>
        </div>

        <div class="reviews-controls">
          <button type="button" class="carousel-button" data-carousel-prev aria-label="Previous review"><Fragment set:html={leftArrowHtml} /></button>
          <div class="carousel-dots" data-carousel-dots></div>
          <button type="button" class="carousel-button" data-carousel-next aria-label="Next review"><Fragment set:html={rightArrowHtml} /></button>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section section-block" id="faq">
    <div class="container faq-inner">
      <div class="section-head reveal">
        <div class="section-label">FAQ</div>
        <h2>Common questions</h2>
      </div>

      <div class="faq-list reveal">
        <details class="faq-item">
          <summary>
            <span>Do I need gym experience to use maatriks?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <div class="faq-answer">
            <p>No. Tell it your schedule and goals, and it builds your first workout from there. You do not need to know exercises or programming. The app handles that. Experienced lifters get the same adaptive engine without managing their own spreadsheets.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary>
            <span>How does the app know what to change after each workout?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <div class="faq-answer">
            <p>It uses what you actually logged: sets, reps, weight, and any swaps you made. If you went heavier, it adjusts up. If you cut a session short, it adapts. Every workout informs the next one.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary>
            <span>Can I change exercises during a workout?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <div class="faq-answer">
            <p>Yes. Swap anything mid-session and the app treats it as part of the record. Your plan adjusts based on what you actually did, not what was originally scheduled.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary>
            <span>Is this a fixed workout plan or does it change?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <div class="faq-answer">
            <p>It changes. You start with a structured plan based on your setup, but after each session the app reviews what happened and adjusts what comes next. The longer you use it, the more tailored it gets.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary>
            <span>How is this different from a personal trainer?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <div class="faq-answer">
            <p>A trainer costs 50-120 per session. maatriks gives you a personalized plan that adapts after every workout, with written feedback explaining what changed and why. It is not a human coach, but it pays closer attention than a static app or a spreadsheet.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <section class="newsletter-section section-block" id="newsletter">
    <div class="container newsletter-inner reveal">
      <div class="section-label">Newsletter</div>
      <h2>Get training tips that actually help</h2>
      <p>Simple advice for getting stronger, app updates, and early access to new features. One email a week, no spam.</p>

      <form class="newsletter-form" data-newsletter-form>
        <label class="sr-only" for="newsletter-email">Email address</label>
        <input id="newsletter-email" name="email" type="email" placeholder="you@domain.com" autocomplete="email" required />
        <button type="submit" class="btn btn-primary">Join Newsletter</button>
      </form>
      <p class="newsletter-note" data-newsletter-note></p>
    </div>
  </section>

  <section class="download-section section-block" id="download">
    <div class="container download-inner reveal">
      <div class="section-label">Download</div>
      <h2>Your first workout is one setup away</h2>
      <p>Download maatriks, answer a few questions, and get a plan built for you. It gets smarter every session.</p>

      <div class="download-actions">
        <LegacyPartial name="store-badges" />
      </div>
    </div>
  </section>
</BaseLayout>
