---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailLink from '../components/EmailLink.astro';
import { siteConfig } from '../lib/site.mjs';

const relatedPages = [
  { href: siteConfig.forgotPasswordUrl, label: 'Reset Password', description: 'how password recovery works' },
  { href: siteConfig.privacyUrl, label: 'Privacy Policy', description: 'how we handle your data' },
  { href: siteConfig.termsUrl, label: 'Terms & Conditions', description: 'the rules for using the app and website' },
  { href: siteConfig.deleteAccountUrl, label: 'Delete Account', description: 'how to remove your account and data' },
];
---

<BaseLayout
  pageTitle={`Support — ${siteConfig.appName}`}
  pageDescription={`Get help with ${siteConfig.appName}. Contact ${siteConfig.supportEmail}.`}
  canonicalUrl={`${siteConfig.siteUrl}/support`}
  pageClass="content-page"
>
  <div class="container">
    <div class="section-label">Help</div>
    <h1>Support</h1>
    <p class="page-meta">We're here to help</p>

    <div class="content-body">
      <p class="lead">If you need help with {siteConfig.appName}, reach out to us by email. We aim to respond within 2 business days. For account access, password-reset, or deletion requests, contact us from the email address tied to your account whenever possible.</p>

      <EmailLink email={siteConfig.supportEmail} />

      <h2>What we can help with</h2>

      <div class="quick-links" style="margin-top:24px;margin-bottom:32px;">
        <div class="card">
          <h3>Login issues</h3>
          <p>Problems signing in with email, Google, or Apple? Trouble returning to the app after a sign-in link? We can help you recover access.</p>
        </div>
        <div class="card">
          <h3>Password reset</h3>
          <p>If the in-app password reset is not working, the reset email does not arrive, or the handoff page does not reopen the app, start with our <a href={siteConfig.forgotPasswordUrl}>password reset help page</a> or contact us directly.</p>
        </div>
        <div class="card">
          <h3>Account deletion</h3>
          <p>Need help deleting your account? See our <a href={siteConfig.deleteAccountUrl}>deletion page</a> for instructions, or email us directly if you cannot access the app.</p>
        </div>
        <div class="card">
          <h3>General app help</h3>
          <p>Questions about workout feedback, training plans, privacy, or how {siteConfig.appName} uses your data? We can help.</p>
        </div>
      </div>

      <h2>When contacting us</h2>
      <p>To help us resolve your issue quickly, please include:</p>
      <ul>
        <li>The email address associated with your account</li>
        <li>A description of the issue</li>
        <li>Your device type (iPhone, Android) and app version if relevant</li>
        <li>Whether the issue happened during sign-in, password reset, or account deletion</li>
        <li>Screenshots if applicable</li>
      </ul>

      <div class="section-divider"></div>

      <h2>Related pages</h2>
      <ul>
        {relatedPages.map((page) => (
          <li><a href={page.href}>{page.label}</a> {'\u2014'} {page.description}</li>
        ))}
      </ul>
    </div>
  </div>
</BaseLayout>
